@using DemoApp.Web.Models
@model IEnumerable<Role>
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Administrar Roles";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var context = HttpContextAccessor.HttpContext;
    var isAdmin = context?.Session.GetString("IsAdmin") == "true";

    bool HasPermission(string key) =>
        (context?.Items[key] as bool? == true) || isAdmin;
}

<h2>Administrar Roles</h2>

<div class="row">
    <div class="col-md-12">
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Activo</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var role in Model)
                    {
                        <tr>
                            <td>@role.RoleName</td>
                            <td>@(role.IsActive ? "Sí" : "No")</td>
                            <td>
                                @if (HasPermission("CanEdit"))
                                {
                                    <a asp-action="Edit" asp-controller="Roles" asp-route-id="@role.RoleId" class="btn btn-warning btn-sm">
                                        Editar
                                    </a>
                                }

                                @if (HasPermission("CanDelete"))
                                {
                                    <a asp-action="Delete" asp-controller="Roles" asp-route-id="@role.RoleId" class="btn btn-danger btn-sm">
                                        Eliminar
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (HasPermission("CanAdd"))
{
    <a asp-action="Create" asp-controller="Roles" class="btn btn-primary">Crear Nuevo Rol</a>
}
