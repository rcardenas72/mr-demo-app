@model DemoApp.Web.Models.Menu

@{
    ViewData["Title"] = "Eliminar Menu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Eliminar Menu</h2>

<div class="alert alert-warning mb-4">
    <p><strong>¿Está seguro de que desea eliminar este menu?</strong></p>
    <dl class="row mb-0">
        <dt class="col-sm-3">Nombre del menú:</dt>
        <dd class="col-sm-9">@Model.MenuName</dd>

        <dt class="col-sm-3">Controlador:</dt>
        <dd class="col-sm-9">@Model.ControllerName</dd>

        <dt class="col-sm-3">Entidad:</dt>
        <dd class="col-sm-9">@Model.EntityName</dd>
    </dl>
</div>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(false, "", new { @class = "text-danger" })
    <input type="hidden" asp-for="MenuId" />

    <div class="mb-3">
        <button type="submit" class="btn btn-danger">Eliminar</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </div>
</form>
