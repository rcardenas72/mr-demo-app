@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/bootstrap-icons.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site-layout.css" asp-append-version="true" />
</head>
<body>
    <div class="demo-banner text-center py-2">
        <i class="bi bi-info-circle me-1"></i> DEMO — Aplicaci&oacute;n de prueba de MR Soluciones Integrales. Los datos se reinician al reiniciar el servidor.
        <a href="https://www.mrsolucionesint.com">Volver al sitio</a>
    </div>
    @await Html.PartialAsync("_NavBar")
    <div class="wrapper d-flex">
        @await Html.PartialAsync("_Sidebar")
        <div class="content flex-grow-1">
            <button class="btn btn-sm d-md-none mb-2 menu-toggle-btn" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarOffcanvas">
                <i class="bi bi-list"></i> Men&uacute;
            </button>
            @RenderBody()
        </div>
    </div>
    @await Html.PartialAsync("_Footer")

    <script src="~/lib/jquery/dist/jquery.min.js" nonce="@Context.Items["ScriptNonce"]" asp-append-version="true"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" nonce="@Context.Items["ScriptNonce"]" asp-append-version="true"></script>

    @RenderSection("scripts", required: false)

</body>
</html>
